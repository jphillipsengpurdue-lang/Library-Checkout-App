{
  "name": "library-checkout-app",
  "version": "1.0.0",
  "description": "A library management system for non-profits with educational source code viewing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:local": "npm start",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "setup:chromeos": "bash ./scripts/chromeos/one-click-setup.sh",
    "start:server": "node lan-server.js",
    "dist:win": "electron-builder --win nsis",
    "dist:win:portable": "electron-builder --win portable",
    "rebuild:electron": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "library",
    "education",
    "non-profit",
    "electron",
    "sqlite",
    "books"
  ],
  "author": "Boys and Girls Club of Indianapolis",
  "license": "MIT",
  "devDependencies": {
    "electron": "^22.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "sql.js": "^1.8.0",
    "sqlite3": "^5.1.7",
    "express": "^4.21.2"
  },
  "build": {
    "appId": "org.nonprofit.library-checkout",
    "productName": "Library Checkout App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/node_modules/*/{README,README.md,readme.md,CHANGELOG,LICENSE,.npmignore}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/.*"
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/book_2_24dp_EE7B2F_FILL0_wght400_GRAD0_opsz24.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Library Checkout App"
    }
  }
}
